{
  "name": "track",
  "version": "1.0.0",
  "description": "A Chrome extension that calculates driving road distance between two locations and injects the result into an existing element on any web page. Powered by [OpenRouteService](https://openrouteservice.org/) via a Cloudflare Worker proxy — no API key required for end users.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --platform=browser",
    "watch": "esbuild src/content.js --bundle --outfile=dist/content.js --format=iife --platform=browser --watch",
    "package": "npm run build && node scripts/package.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamshodisaev/road-distance-extension.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shamshodisaev/road-distance-extension/issues"
  },
  "homepage": "https://github.com/shamshodisaev/road-distance-extension#readme",
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
